#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

cd "${REPO_ROOT}"   # <-- CRITICAL: make relative paths work

ENV_FILE="${REPO_ROOT}/.env.local"
if [[ -f "${ENV_FILE}" ]]; then
  echo "Loading environment from ${ENV_FILE}"
  set -a
  source "${ENV_FILE}"
  echo "CONF_BASE_URL=${CONF_BASE_URL:-<empty>}"

if [[ -n "${CONF_PAT:-}" ]]; then
  echo "CONF_PAT length=${#CONF_PAT}"
else
  echo "CONF_PAT length=0"
fi

  echo "CONF_SPACE_KEY_PROD=${CONF_SPACE_KEY_PROD:-<empty>}"
  echo "CONF_ROOT_PAGE_ID_PROD=${CONF_ROOT_PAGE_ID_PROD:-<empty>}"
  echo "CONF_SPACE_KEY_STAGING=${CONF_SPACE_KEY_STAGING:-<empty>}"
  echo "CONF_ROOT_PAGE_ID_STAGING=${CONF_ROOT_PAGE_ID_STAGING:-<empty>}"
  echo "CONF_DOCS_DIR=${CONF_DOCS_DIR:-confluence}"
  set +a
else
  echo "WARN: ${ENV_FILE} not found. Environment variables missing."
fi

BRANCH="${1:-$(git -C "${REPO_ROOT}" rev-parse --abbrev-ref HEAD)}"
export BRANCH

echo "Publishing branch: ${BRANCH}"
echo "PWD: $(pwd)"
echo "CONF_DOCS_DIR: ${CONF_DOCS_DIR:-confluence}"

python -u "${REPO_ROOT}/tools/publish_confluence.py"
echo "Python exit code: $?"
