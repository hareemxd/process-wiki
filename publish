#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

ENV_FILE="${REPO_ROOT}/.env.local"
if [[ -f "${ENV_FILE}" ]]; then
  echo "Loading environment from ${ENV_FILE}"
  set -a
  source "${ENV_FILE}"
  set +a
else
  echo "WARN: ${ENV_FILE} not found. Environment variables missing."
fi

BRANCH="${1:-$(git -C "${REPO_ROOT}" rev-parse --abbrev-ref HEAD)}"
export BRANCH

echo "Publishing branch: ${BRANCH}"
python "${REPO_ROOT}/tools/publish_confluence.py"
